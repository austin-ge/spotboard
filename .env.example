# Database
DATABASE_URL=postgresql://spotboard:changeme@db:5432/spotboard

# NextAuth
NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=https://spotboard.xyz

# Mapbox (token is URL-restricted to spotboard.xyz + localhost:3000)
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-token

# ADS-B aggregator (readsb container)
READSB_URL=http://readsb:80

# OAuth (optional)
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=
