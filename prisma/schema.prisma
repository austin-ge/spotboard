generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  JUMPER
  STAFF
  OPERATOR
  ADMIN
}

enum InviteRole {
  MANAGER
  STAFF
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ClaimType {
  OPERATOR
  STAFF
}

enum HeadingMode {
  AUTO
  RUNWAY
  FIXED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole  @default(JUMPER)
  accounts      Account[]
  sessions      Session[]
  dropzones     Dropzone[]
  managedDZs    DropzoneManager[]
  staffAt       DropzoneStaff[]
  claims        DropzoneClaim[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Dropzone {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  owner       User     @relation(fields: [ownerId], references: [id])
  ownerId     String
  isPublic    Boolean  @default(true)
  website     String?
  verifiedDomains String[] @default([])

  // Location
  lat         Float
  lon         Float

  // Airport
  airportCode String?

  // ADS-B
  adsbPrimaryUrl   String?
  adsbFallbackUrl  String?

  // Jump profile
  exitAltitudeFt        Int @default(14000)
  openingAltitudeFt     Int @default(4000)
  holdingAreaAltitudeFt Int @default(2500)
  patternAltitudeFt     Int @default(1000)
  jumpRunAirspeedKnots  Int @default(90)

  // Heading
  headingMode        HeadingMode @default(AUTO)
  fixedHeadingDeg    Int?
  runwayHeading1Deg  Int?
  runwayHeading2Deg  Int?

  // Drift parameters
  canopyForwardSpeedMph         Float?
  canopyDescentRateMph          Float?
  freefallTerminalVelocityMph   Float?
  lightToDoorMiles              Float?
  airplaneDriftMiles            Float?
  maxOffsetMiles                Float?
  jumpRunLengthMiles            Float?

  // Airplane
  aircraftName          String?
  aircraftCruiseSpeedKts Int?

  // Separation
  separationTableJson   Json?

  // Jump planes
  jumpPlanes JumpPlane[]

  // Team
  managers DropzoneManager[]
  staff    DropzoneStaff[]
  claims   DropzoneClaim[]
  invites  DropzoneInvite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JumpPlane {
  id         String   @id @default(cuid())
  dropzone   Dropzone @relation(fields: [dropzoneId], references: [id], onDelete: Cascade)
  dropzoneId String
  hexCode    String   // ICAO 24-bit hex (lowercase)
  tailNumber String?
}

model DropzoneManager {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  dropzone   Dropzone @relation(fields: [dropzoneId], references: [id], onDelete: Cascade)
  dropzoneId String
  createdAt  DateTime @default(now())
  @@unique([userId, dropzoneId])
}

model DropzoneStaff {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  dropzone   Dropzone @relation(fields: [dropzoneId], references: [id], onDelete: Cascade)
  dropzoneId String
  createdAt  DateTime @default(now())
  @@unique([userId, dropzoneId])
}

model DropzoneInvite {
  id         String     @id @default(cuid())
  dropzone   Dropzone   @relation(fields: [dropzoneId], references: [id], onDelete: Cascade)
  dropzoneId String
  email      String?
  token      String     @unique @default(cuid())
  role       InviteRole
  used       Boolean    @default(false)
  usedBy     String?
  createdAt  DateTime   @default(now())
  expiresAt  DateTime
}

model DropzoneClaim {
  id          String      @id @default(cuid())
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  dropzone    Dropzone    @relation(fields: [dropzoneId], references: [id], onDelete: Cascade)
  dropzoneId  String
  claimType   ClaimType
  status      ClaimStatus @default(PENDING)
  emailDomain String
  createdAt   DateTime    @default(now())
  resolvedAt  DateTime?
  resolvedBy  String?
  @@unique([userId, dropzoneId])
}
